# Scorely Environment Variables
# Copy this file to .env and update with your values

# Audiveris Configuration
# Path to Audiveris executable or JAR file
AUDIVERIS_PATH=/Applications/Audiveris.app/Contents/MacOS/Audiveris

# API Configuration
API_PORT=8000
AUDIVERIS_PORT=8081

# Firebase/Supabase (for future realtime features)
# FIREBASE_API_KEY=your_key_here
# SUPABASE_URL=your_url_here
# SUPABASE_KEY=your_key_here
